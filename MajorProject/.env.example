# =============================================
# ESG Greenwashing Detection System - Environment Variables
# Copy this to .env and fill in your API keys
# =============================================

# =============================================
# REQUIRED: LLM API Keys (at least one required)
# =============================================
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================
# NEWS API Keys (for evidence gathering)
# =============================================
# NewsAPI.org - 80,000+ sources (Free: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# NewsData.io - Indian news coverage (Free: 200 req/day)
NEWSDATA_KEY=your_newsdata_key_here

# TheNewsAPI - Unlimited free tier
THENEWSAPI_KEY=your_thenewsapi_key_here

# Mediastack - 500/month free
MEDIASTACK_KEY=your_mediastack_key_here

# =============================================
# US REGULATORY APIs
# =============================================
# SEC API - For Edgar filings
SEC_API_KEY=your_sec_api_key_here

# =============================================
# REGIONAL CONFIGURATION
# =============================================
# Default jurisdiction for regulatory checks
# Options: India, EU, US, UK, Global
DEFAULT_JURISDICTION=India

# =============================================
# ML MODEL CONFIGURATION
# =============================================
# ClimateBERT NLP (HuggingFace)
CLIMATEBERT_ENABLED=true
CLIMATEBERT_USE_GPU=false
# Optional but recommended for higher HF Hub rate limits
HF_TOKEN=

# SHAP/LIME Explainability
SHAP_ENABLED=true
LIME_ENABLED=true

# =============================================
# LANGGRAPH CONFIGURATION
# =============================================
USE_LANGGRAPH=true

# =============================================
# OPTIONAL: Indian-Specific APIs
# =============================================
# Note: Most Indian regulatory data is accessible without APIs
# These are optional for enhanced coverage

# World Bank Climate API (Usually no key required)
WORLD_BANK_API_KEY=

# =============================================
# OPTIONAL: Additional Global APIs
# =============================================
# OpenCorporates
OPENCORPORATES_API_KEY=

# =============================================
# CACHE CONFIGURATION
# =============================================
# Evidence cache duration in hours
EVIDENCE_CACHE_HOURS=24

# =============================================
# DEBUG CONFIGURATION
# =============================================
DEBUG_MODE=false
VERBOSE_LOGGING=false

# Trained models
ml_models/trained/

# Large or local-only data (optional)
data/*.csv
data/*.parquet
data/raw/
data/tmp/

# Local notebooks & artifacts (optional)
notebooks/.ipynb_checkpoints/
*.ckpt
*.pkl
*.joblib
*.h5
